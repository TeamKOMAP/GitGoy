<UserControl x:Class="Vcs.Desktop.Views.RepositorySetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SetupTextBoxStyle"
               TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#858899"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="32,28,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Новый репозиторий"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
                <TextBlock Text="Выберите папку проекта, файлы из нее будут отображаться в изменениях и попадать в коммит."
                           Margin="0,8,0,0"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="52"
                        Background="#000000"
                        Padding="18,0">
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="&#xE8B7;"
                                   Width="24"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedFolder}"
                                   Margin="12,0,0,0"
                                   Foreground="#FFFFFF"
                                   FontSize="15"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Папка проекта"
                                   Margin="12,0,0,0"
                                   Foreground="#858899"
                                   FontSize="15"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFolder}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <Button Grid.Column="2"
                        Content="Выбрать"
                        Style="{StaticResource SquareBlackButtonStyle}"
                        Height="52"
                        Command="{Binding BrowseFolderCommand}" />
            </Grid>

            <TextBox Grid.Row="4"
                     Text="{Binding RepositoryName, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Название репозитория"
                     Style="{StaticResource SetupTextBoxStyle}" />

            <TextBox Grid.Row="6"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Описание репозитория"
                     Style="{StaticResource SetupTextBoxStyle}" />

            <Button Grid.Row="8"
                    Content="{Binding CreateButtonText}"
                    Style="{StaticResource BlackButtonStyle}"
                    Height="52"
                    Command="{Binding CreateRepositoryCommand}" />

            <Border Grid.Row="10"
                    Background="#000000"
                    Padding="14,10"
                    Visibility="{Binding StatusVisibility, Converter={StaticResource VisibilityTextConverter}}">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#FFFFFF"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</UserControl>

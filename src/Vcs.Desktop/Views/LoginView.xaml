<UserControl x:Class="Vcs.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="LoginTextBoxStyle"
               TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="54" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="18,0,18,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#858899"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle"
               TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="54" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="18,0,18,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1"
              Width="420"
              MaxWidth="420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,10">
                <TextBlock Text="{Binding TitleText}"
                           Foreground="#FFFFFF"
                           FontSize="32"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding SubtitleText}"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="16" />
            </StackPanel>

            <TextBox Grid.Row="2"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Логин"
                     Style="{StaticResource LoginTextBoxStyle}" />

            <Grid Grid.Row="4">
                <PasswordBox x:Name="PasswordInput"
                             GotKeyboardFocus="PasswordInput_GotKeyboardFocus"
                             LostKeyboardFocus="PasswordInput_LostKeyboardFocus"
                             PasswordChanged="PasswordInput_PasswordChanged"
                             KeyDown="PasswordInput_KeyDown"
                             Style="{StaticResource LoginPasswordBoxStyle}" />
                <TextBlock Text="Пароль"
                           Margin="18,0,18,0"
                           Foreground="#858899"
                           FontSize="18"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="{Binding PasswordPlaceholderVisibility, Converter={StaticResource VisibilityTextConverter}}" />
            </Grid>

            <Button Grid.Row="6"
                    Content="{Binding LoginButtonText}"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource BlackButtonStyle}"
                    Height="52" />

            <Border Grid.Row="8"
                    Background="#000000"
                    CornerRadius="8"
                    Padding="14,10"
                    Visibility="{Binding ErrorVisibility, Converter={StaticResource VisibilityTextConverter}}">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="&#xE783;"
                               Width="24"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="15"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="8,0,0,0"
                               Foreground="#FFFFFF"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

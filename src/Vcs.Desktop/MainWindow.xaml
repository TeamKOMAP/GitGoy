<Window x:Class="Vcs.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VCS Desktop"
        Height="760"
        MinHeight="640"
        Width="1180"
        MinWidth="980"
        Background="{StaticResource PageBrush}">
    <Window.Resources>
        <Style x:Key="SidebarNavButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111118" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                x:Name="SidebarBorder"
                Width="72"
                Margin="8,10,0,10"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="18"
                ClipToBounds="True">
            <Grid>
                <Grid Margin="6,14,6,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding ShowProfileCommand}"
                            ToolTip="Профиль">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="&#xE77B;"
                                       Width="44"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="23"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Профиль"
                                       Margin="8,0,0,0"
                                       FontSize="20"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SidebarLabelVisibility, Converter={StaticResource VisibilityTextConverter}}" />
                        </DockPanel>
                    </Button>

                    <Border Grid.Row="1"
                            Height="2"
                            Margin="6,8,6,12"
                            Background="#FFFFFF"
                            CornerRadius="1"
                            Visibility="{Binding SidebarLabelVisibility, Converter={StaticResource VisibilityTextConverter}}" />

                    <Button Grid.Row="2"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding ShowProjectCommand}"
                            ToolTip="Репозиторий"
                            VerticalAlignment="Top">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="&#xE8B7;"
                                       Width="44"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="23"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Репозиторий"
                                       Margin="8,0,0,0"
                                       FontSize="20"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SidebarLabelVisibility, Converter={StaticResource VisibilityTextConverter}}" />
                        </DockPanel>
                    </Button>

                    <Button Grid.Row="3"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding ExitCommand}"
                            ToolTip="Выход">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="&#xE8AC;"
                                       Width="44"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="23"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Выход"
                                       Margin="8,0,0,0"
                                       FontSize="20"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SidebarLabelVisibility, Converter={StaticResource VisibilityTextConverter}}" />
                        </DockPanel>
                    </Button>
                </Grid>

                <primitives:Thumb Width="12"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Stretch"
                                  Cursor="SizeWE"
                                  Background="Transparent"
                                  DragDelta="SidebarEdge_DragDelta"
                                  DragCompleted="SidebarEdge_DragCompleted">
                    <primitives:Thumb.Template>
                        <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </primitives:Thumb.Template>
                </primitives:Thumb>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
